{
  "name": "enrow/enrow",
  "description": "Official PHP SDK for the Enrow API — find and verify professional emails and phone numbers",
  "type": "library",
  "license": "MIT",
  "keywords": ["enrow", "email-finder", "email-verifier", "phone-finder", "api", "sdk"],
  "homepage": "https://docs.enrow.io",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Enrow\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Enrow\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
